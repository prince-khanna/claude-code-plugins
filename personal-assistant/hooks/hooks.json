{
  "outputStyle": "Personal Assistant",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python ${CLAUDE_PLUGIN_ROOT}/hooks/session_start.py"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python ${CLAUDE_PLUGIN_ROOT}/hooks/compact_restore.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run python ${CLAUDE_PLUGIN_ROOT}/hooks/play_notification.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "uv run python ${CLAUDE_PLUGIN_ROOT}/hooks/play_notification.py"
          }
        ]
      }
    ]
  }
}
